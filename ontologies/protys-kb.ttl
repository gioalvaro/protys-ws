@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:       <http://purl.org/dc/elements/1.1/> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix protys:   <http://www.protys.org/ontology/> .

# ============================================================================
# PROTYS(KB) - Ontology Network for Semantic Interoperability in Manufacturing
# Master Ontology - Imports all modules
# ============================================================================

protys:protys-kb a owl:Ontology ;
    owl:versionIRI <http://www.protys.org/ontology/protys-kb/1.0> ;
    dc:title "PROTYS(KB) - Knowledge Base for Manufacturing Interoperability"@en ;
    dc:title "PROTYS(KB) - Base de Conocimiento para Interoperabilidad en Manufactura"@es ;
    dc:creator "Álvaro Fraga Moreira" ;
    dc:description """PROTYS(KB) is an ontology network designed to enable semantic
    interoperability between heterogeneous manufacturing information systems (ERP, MES,
    SCADA, LIMS). It integrates domain concepts from international standards ISO 14040
    (Life Cycle Assessment) and ISO 15531 (MANDATE - Manufacturing Data) through a
    modular architecture with SWRL-based alignment rules."""@en ;
    dc:date "2025-01-01"^^xsd:date ;
    dc:rights "Academic Use - PhD Thesis, Universidad de Carabobo" ;
    dcterms:license <http://creativecommons.org/licenses/by-nc-sa/4.0/> ;
    owl:versionInfo "1.0" ;

    # Module imports
    owl:imports protys:core-concepts ;
    owl:imports protys:product-module ;
    owl:imports protys:process-module ;
    owl:imports protys:resource-module ;
    owl:imports protys:enterprise-module ;
    owl:imports protys:iso14040-module ;
    owl:imports protys:iso15531-module ;
    owl:imports protys:alignment-rules ;

    # Annotations about the network
    rdfs:comment """
    Architecture: 7 domain modules + 1 alignment module = 8 OWL ontologies

    Core Layer:
      - core-concepts.owl     : 12 foundational classes (Product, Process, Resource, etc.)

    Domain Modules:
      - product-module.owl    : 8 classes (Raw_Material, Formulation, ProductBatch, etc.)
      - process-module.owl    : 10 classes (Manufacturing_Stage, QualityControl, etc.)
      - resource-module.owl   : 9 classes (Equipment, HumanResource, ProductionLine, etc.)
      - enterprise-module.owl : 7 classes (Organization, Plant, Workshop, etc.)

    Standard Modules:
      - iso14040-module.owl   : 15 classes (LCA, ImpactAssessment, ElementaryFlow, etc.)
      - iso15531-module.owl   : 18 classes (ProcessPlan, WorkOrder, PerformanceMetric, etc.)

    Integration:
      - alignment-rules.owl   : 26 SWRL rules (R01-R26) + 7 equivalence axioms

    Metrics:
      - Total classes: 79
      - Total object properties: 51
      - Total data properties: 44
      - Total SWRL rules: 26
      - Total equivalence axioms: 7
    """@en .

# ============================================================================
# Named Graph Mapping (for Fuseki deployment)
# ============================================================================
# urn:protys:core        → core-concepts.owl
# urn:protys:product     → product-module.owl
# urn:protys:process     → process-module.owl
# urn:protys:resource    → resource-module.owl
# urn:protys:enterprise  → enterprise-module.owl
# urn:protys:iso14040    → iso14040-module.owl
# urn:protys:iso15531    → iso15531-module.owl
# urn:protys:alignment   → alignment-rules.owl
# urn:protys:kb          → protys-kb.ttl (this file)
# urn:protys:instances   → paint-case-study-instances.ttl
# urn:protys:erp:adempiere → paint-instances-adempiere.ttl
# urn:protys:erp:odoo    → paint-instances-odoo.ttl
