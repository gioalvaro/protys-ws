<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:protys="http://protys.ingar.conicet.gob.ar/ontology#"
         xml:base="http://protys.ingar.conicet.gob.ar/ontology#">

    <owl:Ontology rdf:about="http://protys.ingar.conicet.gob.ar/ontology/resource-module">
        <rdfs:label>PROTYS Resource Module</rdfs:label>
        <rdfs:comment>Resource classification including equipment, personnel, and energy for manufacturing operations</rdfs:comment>
        <owl:versionInfo>1.0</owl:versionInfo>
        <owl:imports rdf:resource="http://protys.ingar.conicet.gob.ar/ontology/core-concepts"/>
    </owl:Ontology>

    <!-- ========================================
         RESOURCE CLASSES
         ======================================== -->

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Device">
        <rdfs:label>Device</rdfs:label>
        <rdfs:comment>A general mechanical or electrical device used in manufacturing</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Equipment"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Equip">
        <rdfs:label>Equipment</rdfs:label>
        <rdfs:comment>Industrial equipment used for manufacturing processes</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Resource"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#HumanResource">
        <rdfs:label>Human Resource</rdfs:label>
        <rdfs:comment>Personnel with skills and competencies for manufacturing tasks</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Person"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#EnergyResource">
        <rdfs:label>Energy Resource</rdfs:label>
        <rdfs:comment>Energy sources such as electricity, steam, or thermal energy</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Resource"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#WorkCell">
        <rdfs:label>Work Cell</rdfs:label>
        <rdfs:comment>A group of integrated equipment forming a manufacturing unit</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Equipment"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#ProductionLine">
        <rdfs:label>Production Line</rdfs:label>
        <rdfs:comment>A series of work cells connected for sequential manufacturing</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Equipment"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Sensor">
        <rdfs:label>Sensor</rdfs:label>
        <rdfs:comment>A device for measuring and monitoring process parameters</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Device"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Tool">
        <rdfs:label>Tool</rdfs:label>
        <rdfs:comment>A hand tool or implement used in manufacturing operations</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Equipment"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Consumable">
        <rdfs:label>Consumable</rdfs:label>
        <rdfs:comment>Expendable resources consumed during manufacturing</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Resource"/>
    </owl:Class>

    <!-- ========================================
         RESOURCE OBJECT PROPERTIES
         ======================================== -->

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasCapacity">
        <rdfs:label>has Capacity</rdfs:label>
        <rdfs:comment>The production capacity of a resource</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Equipment"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasEnergyConsumption">
        <rdfs:label>has Energy Consumption</rdfs:label>
        <rdfs:comment>The energy consumption rate of a resource</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Equipment"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasAvailability">
        <rdfs:label>has Availability</rdfs:label>
        <rdfs:comment>The availability or uptime percentage of a resource</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Equipment"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasOEE">
        <rdfs:label>has OEE</rdfs:label>
        <rdfs:comment>The Overall Equipment Effectiveness (OEE) metric</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Equipment"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasMaintenanceSchedule">
        <rdfs:label>has Maintenance Schedule</rdfs:label>
        <rdfs:comment>The preventive maintenance schedule for a resource</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Equipment"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasSkill">
        <rdfs:label>has Skill</rdfs:label>
        <rdfs:comment>A skill possessed by a human resource</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#HumanResource"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Capability"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasCertification">
        <rdfs:label>has Certification</rdfs:label>
        <rdfs:comment>A certification or qualification held by a person</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#HumanResource"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#isAuthorizedFor">
        <rdfs:label>is Authorized For</rdfs:label>
        <rdfs:comment>A process or task that a resource is authorized to perform</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Resource"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
    </owl:ObjectProperty>

    <!-- ========================================
         RESOURCE DATA PROPERTIES
         ======================================== -->

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#capacityLitersPerHour">
        <rdfs:label>capacity Liters Per Hour</rdfs:label>
        <rdfs:comment>Capacity in liters per hour</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#capacityUnitsPerMinute">
        <rdfs:label>capacity Units Per Minute</rdfs:label>
        <rdfs:comment>Capacity in units per minute</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#energyConsumptionKW">
        <rdfs:label>energy Consumption KW</rdfs:label>
        <rdfs:comment>Energy consumption in kilowatts</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#availabilityPercent">
        <rdfs:label>availability Percent</rdfs:label>
        <rdfs:comment>Availability as a percentage</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#OEEPercent">
        <rdfs:label>OEE Percent</rdfs:label>
        <rdfs:comment>Overall Equipment Effectiveness as a percentage</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#yearOfExperience">
        <rdfs:label>year Of Experience</rdfs:label>
        <rdfs:comment>Years of work experience</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#certificationLevel">
        <rdfs:label>certification Level</rdfs:label>
        <rdfs:comment>Level or grade of certification</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#skillCategory">
        <rdfs:label>skill Category</rdfs:label>
        <rdfs:comment>Category or classification of a skill</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#maintenanceFrequencyDays">
        <rdfs:label>maintenance Frequency Days</rdfs:label>
        <rdfs:comment>Maintenance frequency in days</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    </owl:DatatypeProperty>

</rdf:RDF>
