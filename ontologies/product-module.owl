<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:protys="http://protys.ingar.conicet.gob.ar/ontology#"
         xml:base="http://protys.ingar.conicet.gob.ar/ontology#">

    <owl:Ontology rdf:about="http://protys.ingar.conicet.gob.ar/ontology/product-module">
        <rdfs:label>PROTYS Product Module</rdfs:label>
        <rdfs:comment>Product hierarchy and classification for manufacturing interoperability</rdfs:comment>
        <owl:versionInfo>1.0</owl:versionInfo>
        <owl:imports rdf:resource="http://protys.ingar.conicet.gob.ar/ontology/core-concepts"/>
    </owl:Ontology>

    <!-- ========================================
         PRODUCT CLASSES
         ======================================== -->

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Raw_Material">
        <rdfs:label>Raw Material</rdfs:label>
        <rdfs:comment>Unprocessed or minimally processed material used as input to manufacturing</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Product"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Intermediate_Product">
        <rdfs:label>Intermediate Product</rdfs:label>
        <rdfs:comment>A partially processed product used as input to further manufacturing stages</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Product"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Final_Product">
        <rdfs:label>Final Product</rdfs:label>
        <rdfs:comment>A completed product ready for sale or use</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Product"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Production_Component">
        <rdfs:label>Production Component</rdfs:label>
        <rdfs:comment>A discrete component or part used in assembly or manufacturing</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Product"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Chemical_Compound">
        <rdfs:label>Chemical Compound</rdfs:label>
        <rdfs:comment>A chemical substance with defined composition and properties</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Product"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Formulation">
        <rdfs:label>Formulation</rdfs:label>
        <rdfs:comment>A defined recipe or composition of materials</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Product"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#ProductBatch">
        <rdfs:label>Product Batch</rdfs:label>
        <rdfs:comment>A quantity of product manufactured in a single production run</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Product"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#QualitySpec">
        <rdfs:label>Quality Specification</rdfs:label>
        <rdfs:comment>A specification of quality requirements for a product</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#QualityParameter"/>
    </owl:Class>

    <!-- ========================================
         PRODUCT OBJECT PROPERTIES
         ======================================== -->

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasConcentration">
        <rdfs:label>has Concentration</rdfs:label>
        <rdfs:comment>The concentration of a substance in a formulation or product</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Chemical_Compound"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#QualityParameter"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasPurity">
        <rdfs:label>has Purity</rdfs:label>
        <rdfs:comment>The degree of purity of a material or compound</rdfs:comment>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#QualityParameter"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasShelfLife">
        <rdfs:label>has Shelf Life</rdfs:label>
        <rdfs:comment>The shelf life duration of a product</rdfs:comment>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#QualityParameter"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasMolecularWeight">
        <rdfs:label>has Molecular Weight</rdfs:label>
        <rdfs:comment>The molecular weight of a chemical compound</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Chemical_Compound"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#QualityParameter"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasGlassTransition">
        <rdfs:label>has Glass Transition</rdfs:label>
        <rdfs:comment>The glass transition temperature of a material</rdfs:comment>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#QualityParameter"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasFunction">
        <rdfs:label>has Function</rdfs:label>
        <rdfs:comment>The intended function or application of a product</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Final_Product"/>
    </owl:ObjectProperty>

    <!-- ========================================
         PRODUCT DATA PROPERTIES
         ======================================== -->

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#concentrationValue">
        <rdfs:label>concentration Value</rdfs:label>
        <rdfs:comment>Numeric concentration value</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#purityPercent">
        <rdfs:label>purity Percent</rdfs:label>
        <rdfs:comment>Purity as a percentage</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#shelfLifeMonths">
        <rdfs:label>shelf Life Months</rdfs:label>
        <rdfs:comment>Shelf life in months</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#molecularWeightValue">
        <rdfs:label>molecular Weight Value</rdfs:label>
        <rdfs:comment>Molecular weight in g/mol</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#glassTransitionTemp">
        <rdfs:label>glass Transition Temperature</rdfs:label>
        <rdfs:comment>Glass transition temperature in Celsius</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#viscosity">
        <rdfs:label>viscosity</rdfs:label>
        <rdfs:comment>Viscosity in centiPoise (cP)</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#solidContent">
        <rdfs:label>solid Content</rdfs:label>
        <rdfs:comment>Solid content percentage</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#volatileOrganicCompounds">
        <rdfs:label>volatile Organic Compounds</rdfs:label>
        <rdfs:comment>VOC content in g/L</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#particleSize">
        <rdfs:label>particle Size</rdfs:label>
        <rdfs:comment>Particle size in micrometers</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#batchQuantity">
        <rdfs:label>batch Quantity</rdfs:label>
        <rdfs:comment>Quantity in a batch (in kg)</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

</rdf:RDF>
