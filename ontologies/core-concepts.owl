<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:protys="http://protys.ingar.conicet.gob.ar/ontology#"
         xml:base="http://protys.ingar.conicet.gob.ar/ontology#">

    <owl:Ontology rdf:about="http://protys.ingar.conicet.gob.ar/ontology/core-concepts">
        <rdfs:label>PROTYS Core Concepts Module</rdfs:label>
        <rdfs:comment>Top-level abstract concepts for manufacturing interoperability. Defines the fundamental classes and properties used across all PROTYS modules.</rdfs:comment>
        <owl:versionInfo>1.0</owl:versionInfo>
        <owl:imports rdf:resource="http://www.w3.org/2002/07/owl#"/>
    </owl:Ontology>

    <!-- ========================================
         CORE CLASSES - Top-level Abstract Concepts
         ======================================== -->

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Product">
        <rdfs:label>Product</rdfs:label>
        <rdfs:comment>Something produced by a process or manufacturing activity</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Process">
        <rdfs:label>Process</rdfs:label>
        <rdfs:comment>A sequence of activities or operations that transform inputs into outputs</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Resource">
        <rdfs:label>Resource</rdfs:label>
        <rdfs:comment>An entity (equipment, person, energy, material) used in a process</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Enterprise">
        <rdfs:label>Enterprise</rdfs:label>
        <rdfs:comment>An organizational entity responsible for manufacturing operations</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Standard">
        <rdfs:label>Standard</rdfs:label>
        <rdfs:comment>A norm, specification, or normative document used in manufacturing</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Material">
        <rdfs:label>Material</rdfs:label>
        <rdfs:comment>A tangible substance used in manufacturing processes</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Product"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Equipment">
        <rdfs:label>Equipment</rdfs:label>
        <rdfs:comment>A machine or device used in manufacturing</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Resource"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Person">
        <rdfs:label>Person</rdfs:label>
        <rdfs:comment>A human resource with skills and capabilities</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Resource"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Capability">
        <rdfs:label>Capability</rdfs:label>
        <rdfs:comment>An ability or competence to perform a manufacturing function</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#MaterialFlow">
        <rdfs:label>Material Flow</rdfs:label>
        <rdfs:comment>The movement and transformation of materials through processes</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#QualityParameter">
        <rdfs:label>Quality Parameter</rdfs:label>
        <rdfs:comment>A measurable characteristic of a product or process</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#EnvironmentalIndicator">
        <rdfs:label>Environmental Indicator</rdfs:label>
        <rdfs:comment>A measurable aspect of environmental performance</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:Class>

    <!-- ========================================
         OBJECT PROPERTIES
         ======================================== -->

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasProcess">
        <rdfs:label>has Process</rdfs:label>
        <rdfs:comment>Relates an entity to a process it performs or contains</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasResource">
        <rdfs:label>has Resource</rdfs:label>
        <rdfs:comment>Relates a process or enterprise to its required resources</rdfs:comment>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Resource"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#belongsTo">
        <rdfs:label>belongs To</rdfs:label>
        <rdfs:comment>Relates an entity to the enterprise or organization it belongs to</rdfs:comment>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#produces">
        <rdfs:label>produces</rdfs:label>
        <rdfs:comment>Relates a process or resource to the product it generates</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Product"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#consumes">
        <rdfs:label>consumes</rdfs:label>
        <rdfs:comment>Relates a process to the materials or resources it uses</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Material"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasCapability">
        <rdfs:label>has Capability</rdfs:label>
        <rdfs:comment>Relates a resource to its capabilities</rdfs:comment>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Capability"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#precedes">
        <rdfs:label>precedes</rdfs:label>
        <rdfs:comment>Relates a process to another process that follows it</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#follows">
        <rdfs:label>follows</rdfs:label>
        <rdfs:comment>Inverse of precedes</rdfs:comment>
        <owl:inverseOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#precedes"/>
    </owl:ObjectProperty>

    <!-- ========================================
         DATA PROPERTIES
         ======================================== -->

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasName">
        <rdfs:label>has Name</rdfs:label>
        <rdfs:comment>A textual identifier or name</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasDescription">
        <rdfs:label>has Description</rdfs:label>
        <rdfs:comment>A textual description of an entity</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasVersion">
        <rdfs:label>has Version</rdfs:label>
        <rdfs:comment>Version information</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasURI">
        <rdfs:label>has URI</rdfs:label>
        <rdfs:comment>A unique URI identifier</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>

</rdf:RDF>
