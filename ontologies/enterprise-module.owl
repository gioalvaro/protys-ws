<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:protys="http://protys.ingar.conicet.gob.ar/ontology#"
         xml:base="http://protys.ingar.conicet.gob.ar/ontology#">

    <owl:Ontology rdf:about="http://protys.ingar.conicet.gob.ar/ontology/enterprise-module">
        <rdfs:label>PROTYS Enterprise Module</rdfs:label>
        <rdfs:comment>Organizational structure and enterprise hierarchy for manufacturing operations</rdfs:comment>
        <owl:versionInfo>1.0</owl:versionInfo>
        <owl:imports rdf:resource="http://protys.ingar.conicet.gob.ar/ontology/core-concepts"/>
    </owl:Ontology>

    <!-- ========================================
         ENTERPRISE CLASSES
         ======================================== -->

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Organization">
        <rdfs:label>Organization</rdfs:label>
        <rdfs:comment>A top-level organizational entity</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Plant">
        <rdfs:label>Plant</rdfs:label>
        <rdfs:comment>A manufacturing facility or factory</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Workshop">
        <rdfs:label>Workshop</rdfs:label>
        <rdfs:comment>A specialized work area or workshop within a plant</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Department">
        <rdfs:label>Department</rdfs:label>
        <rdfs:comment>A functional department within an organization</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#ProductionCell">
        <rdfs:label>Production Cell</rdfs:label>
        <rdfs:comment>A focused production unit performing specific operations</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Warehouse">
        <rdfs:label>Warehouse</rdfs:label>
        <rdfs:comment>A storage facility for materials and products</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Supplier">
        <rdfs:label>Supplier</rdfs:label>
        <rdfs:comment>An external organization providing materials or services</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
    </owl:Class>

    <!-- ========================================
         ENTERPRISE OBJECT PROPERTIES
         ======================================== -->

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasLocation">
        <rdfs:label>has Location</rdfs:label>
        <rdfs:comment>The physical location of an enterprise unit</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasLocationCapacity">
        <rdfs:label>has Location Capacity</rdfs:label>
        <rdfs:comment>The production capacity of an enterprise unit</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#employs">
        <rdfs:label>employs</rdfs:label>
        <rdfs:comment>Relates an enterprise to the personnel it employs</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Person"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#manages">
        <rdfs:label>manages</rdfs:label>
        <rdfs:comment>Relates an enterprise unit to other units or resources it manages</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#suppliesTo">
        <rdfs:label>supplies To</rdfs:label>
        <rdfs:comment>Relates a supplier to the enterprises it supplies</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Supplier"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#partOfOrganization">
        <rdfs:label>part Of Organization</rdfs:label>
        <rdfs:comment>Indicates organizational hierarchical relationship</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Enterprise"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Organization"/>
    </owl:ObjectProperty>

    <!-- ========================================
         ENTERPRISE DATA PROPERTIES
         ======================================== -->

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#location">
        <rdfs:label>location</rdfs:label>
        <rdfs:comment>Geographic location information</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#capacityTonsPerMonth">
        <rdfs:label>capacity Tons Per Month</rdfs:label>
        <rdfs:comment>Production capacity in tons per month</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#organizationCode">
        <rdfs:label>organization Code</rdfs:label>
        <rdfs:comment>Unique organizational code or identifier</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#establishedDate">
        <rdfs:label>established Date</rdfs:label>
        <rdfs:comment>Date when the organization was established</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#numberOfEmployees">
        <rdfs:label>number Of Employees</rdfs:label>
        <rdfs:comment>Total number of employees</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    </owl:DatatypeProperty>

</rdf:RDF>
