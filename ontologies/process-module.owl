<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:protys="http://protys.ingar.conicet.gob.ar/ontology#"
         xml:base="http://protys.ingar.conicet.gob.ar/ontology#">

    <owl:Ontology rdf:about="http://protys.ingar.conicet.gob.ar/ontology/process-module">
        <rdfs:label>PROTYS Process Module</rdfs:label>
        <rdfs:comment>Process classification and manufacturing activities for production planning and execution</rdfs:comment>
        <owl:versionInfo>1.0</owl:versionInfo>
        <owl:imports rdf:resource="http://protys.ingar.conicet.gob.ar/ontology/core-concepts"/>
    </owl:Ontology>

    <!-- ========================================
         PROCESS CLASSES
         ======================================== -->

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Artificial_Process">
        <rdfs:label>Artificial Process</rdfs:label>
        <rdfs:comment>A manufacturing process performed by machines or controlled systems</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Natural_Process">
        <rdfs:label>Natural Process</rdfs:label>
        <rdfs:comment>A process that occurs naturally without direct control</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Procedure_Activity">
        <rdfs:label>Procedure Activity</rdfs:label>
        <rdfs:comment>A defined sequence of operations following an established procedure</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Artificial_Process"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Setup_Activity">
        <rdfs:label>Setup Activity</rdfs:label>
        <rdfs:comment>Configuration and preparation activities before manufacturing</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Artificial_Process"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Manufacturing_Stage">
        <rdfs:label>Manufacturing Stage</rdfs:label>
        <rdfs:comment>A distinct phase or stage in the manufacturing process</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#BatchProcess">
        <rdfs:label>Batch Process</rdfs:label>
        <rdfs:comment>A manufacturing process that produces discrete batches of product</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Artificial_Process"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#ContinuousProcess">
        <rdfs:label>Continuous Process</rdfs:label>
        <rdfs:comment>A manufacturing process that operates continuously over time</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Artificial_Process"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#QualityControl">
        <rdfs:label>Quality Control</rdfs:label>
        <rdfs:comment>Activities to verify and maintain product quality standards</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Procedure_Activity"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Inspection">
        <rdfs:label>Inspection</rdfs:label>
        <rdfs:comment>Examination of products or materials to verify conformance</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#QualityControl"/>
    </owl:Class>

    <owl:Class rdf:about="http://protys.ingar.conicet.gob.ar/ontology#Packaging">
        <rdfs:label>Packaging</rdfs:label>
        <rdfs:comment>The process of preparing finished products for shipment and storage</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Manufacturing_Stage"/>
    </owl:Class>

    <!-- ========================================
         PROCESS OBJECT PROPERTIES
         ======================================== -->

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasDuration">
        <rdfs:label>has Duration</rdfs:label>
        <rdfs:comment>The time duration of a process</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasTemperature">
        <rdfs:label>has Temperature</rdfs:label>
        <rdfs:comment>The operating temperature of a process</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasSpeed">
        <rdfs:label>has Speed</rdfs:label>
        <rdfs:comment>The operational speed or throughput of a process</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasPressure">
        <rdfs:label>has Pressure</rdfs:label>
        <rdfs:comment>The operating pressure of a process</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#hasYield">
        <rdfs:label>has Yield</rdfs:label>
        <rdfs:comment>The process yield or efficiency</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#inputMaterial">
        <rdfs:label>input Material</rdfs:label>
        <rdfs:comment>The material consumed by a process</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Product"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#outputProduct">
        <rdfs:label>output Product</rdfs:label>
        <rdfs:comment>The product produced by a process</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Product"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#requiresResource">
        <rdfs:label>requires Resource</rdfs:label>
        <rdfs:comment>The resource required to perform a process</rdfs:comment>
        <rdfs:domain rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Process"/>
        <rdfs:range rdf:resource="http://protys.ingar.conicet.gob.ar/ontology#Resource"/>
    </owl:ObjectProperty>

    <!-- ========================================
         PROCESS DATA PROPERTIES
         ======================================== -->

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#durationMinutes">
        <rdfs:label>duration Minutes</rdfs:label>
        <rdfs:comment>Process duration in minutes</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#temperatureCelsius">
        <rdfs:label>temperature Celsius</rdfs:label>
        <rdfs:comment>Temperature in degrees Celsius</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#speedRPM">
        <rdfs:label>speed RPM</rdfs:label>
        <rdfs:comment>Speed in revolutions per minute</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#pressureBar">
        <rdfs:label>pressure Bar</rdfs:label>
        <rdfs:comment>Pressure in bar</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#yieldPercent">
        <rdfs:label>yield Percent</rdfs:label>
        <rdfs:comment>Yield as a percentage</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#inputQuantity">
        <rdfs:label>input Quantity</rdfs:label>
        <rdfs:comment>Quantity of input material in kg</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#outputQuantity">
        <rdfs:label>output Quantity</rdfs:label>
        <rdfs:comment>Quantity of output product in kg</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://protys.ingar.conicet.gob.ar/ontology#throughput">
        <rdfs:label>throughput</rdfs:label>
        <rdfs:comment>Process throughput in units per minute</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

</rdf:RDF>
