# --- Manufacturing Workflow (from M_Production) ---
erp:process_4000001 a process:Inspection ;
    core:hasName "Inspección de Materia Prima"@es ;
    rdfs:label "Raw Material Inspection"@en ;
    process:durationMinutes 45 ;
    process:yieldPercent 99.5 ;
    process:inputQuantity 1000.0 ;
    process:outputQuantity 995.0 ;
    core:hasResource erp:resource_5000005 .

erp:process_4000002 a process:Manufacturing_Stage ;
    core:hasName "Dispersión de Pigmento en Molino de Perlas"@es ;
    rdfs:label "Pigment Dispersion in Pearl Mill"@en ;
    process:durationMinutes 120 ;
    process:temperatureCelsius 45.0 ;
    process:speedRPM 2800 ;
    process:yieldPercent 97.0 ;
    process:inputQuantity 350.0 ;
    process:outputQuantity 339.5 ;
    process:throughput 175.0 ;
    core:inputMaterial erp:product_2000001 , erp:product_2000003 , erp:product_2000004 ;
    core:outputProduct erp:product_2000010 ;
    core:hasResource erp:resource_5000001 ;
    core:precedes erp:process_4000003 .

erp:process_4000003 a process:Manufacturing_Stage ;
    core:hasName "Mezcla Principal en Reactor"@es ;
    rdfs:label "Main Mixing in Reactor"@en ;
    process:durationMinutes 90 ;
    process:temperatureCelsius 30.0 ;
    process:speedRPM 800 ;
    process:yieldPercent 99.0 ;
    process:inputQuantity 800.0 ;
    process:outputQuantity 792.0 ;
    process:throughput 533.0 ;
    core:inputMaterial erp:product_2000010 , erp:product_2000002 , erp:product_2000003 ,
                       erp:product_2000005 , erp:product_2000006 ;
    core:hasResource erp:resource_5000002 ;
    core:precedes erp:process_4000004 .

erp:process_4000004 a process:Manufacturing_Stage ;
    core:hasName "Ajuste de Viscosidad y pH"@es ;
    rdfs:label "Viscosity and pH Adjustment"@en ;
    process:durationMinutes 30 ;
    process:temperatureCelsius 25.0 ;
    process:yieldPercent 99.8 ;
    process:inputQuantity 792.0 ;
    process:outputQuantity 790.4 ;
    core:inputMaterial erp:product_2000007 , erp:product_2000003 ;
    core:outputProduct erp:product_2000011 ;
    core:hasResource erp:resource_5000002 ;
    core:precedes erp:process_4000005 .

erp:process_4000005 a process:Manufacturing_Stage ;
    core:hasName "Filtración 100 mesh"@es ;
    rdfs:label "100 Mesh Filtration"@en ;
    process:durationMinutes 20 ;
    process:yieldPercent 99.5 ;
    process:inputQuantity 790.4 ;
    process:outputQuantity 786.4 ;
