erp:process_4000006 a process:QualityControl ;
    core:hasName "Control de Calidad - Laboratorio"@es ;
    rdfs:label "Quality Control - Laboratory"@en ;
    process:durationMinutes 60 ;
    process:yieldPercent 100.0 ;
