    rdfs:label "Dosificación Precisa"@es ;
    protys:hasName "Precision_Metering_Capability" .

protys:DryingDrum_04
    rdf:type protys:Equipment ;
    rdfs:label "Drying Drum Unit 04"@en ;
    rdfs:label "Tambor de Secado Unidad 04"@es ;
    protys:hasName "DryingDrum_04" ;
    protys:hasDescription "Industrial drying drum with temperature control 60-120°C and 5-20 rpm rotation" ;
    protys:temperatureCelsius 90.0 ;
    protys:speedRPM 10.0 ;
    protys:availabilityPercent 88.0 ;
    protys:OEEPercent 85.0 ;
    protys:hasCapability protys:Thermal_Drying ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/equipment/DryingDrum_04"^^xsd:anyURI .

protys:Thermal_Drying
    rdf:type protys:ManufacturingCapability ;
    rdfs:label "Thermal Drying"@en ;
    rdfs:label "Secado Térmico"@es ;
    protys:hasName "Thermal_Drying_Capability" .

protys:PackagingMachine_05
    rdf:type protys:Equipment ;
