    rdfs:label "Batch Mixing"@en ;
    rdfs:label "Mezcla por Lotes"@es ;
    protys:hasName "Batch_Mixing_Capability" .

protys:DosingSystem_03
    rdf:type protys:Equipment ;
    rdfs:label "Dosing System Unit 03"@en ;
    rdfs:label "Sistema de Dosificación Unidad 03"@es ;
    protys:hasName "DosingSystem_03" ;
    protys:hasDescription "Precision metering system for additive dosing with ±0.1% accuracy" ;
    protys:capacityLitersPerHour 100.0 ;
    protys:availabilityPercent 95.0 ;
    protys:OEEPercent 92.0 ;
    protys:hasCapability protys:Precision_Metering ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/equipment/DosingSystem_03"^^xsd:anyURI ;
    protys:belongsTo protys:Cell_Mixing .

protys:Precision_Metering
    rdf:type protys:ManufacturingCapability ;
