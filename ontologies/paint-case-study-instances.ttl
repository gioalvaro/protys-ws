# QUALITY SPECIFICATIONS
# ========================================

protys:Viscosity_KU_Spec
    rdf:type protys:QualitySpec ;
    rdfs:label "Viscosity Specification (KU)"@en ;
    rdfs:label "Especificación de Viscosidad (KU)"@es ;
    protys:hasName "Viscosity_85±5_KU" ;
    protys:hasDescription "Viscosity must be 85 ± 5 Krebs Units" ;
