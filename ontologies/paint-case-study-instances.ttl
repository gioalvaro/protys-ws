protys:MixingReactor_02
    rdf:type protys:Equipment ;
    rdfs:label "Mixing Reactor Unit 02"@en ;
    rdfs:label "Reactor Mezclador Unidad 02"@es ;
    protys:hasName "MixingReactor_02" ;
    protys:hasDescription "5000L capacity batch mixing reactor with temperature and speed control" ;
    protys:capacityLitersPerHour 5000.0 ;
    protys:availabilityPercent 90.0 ;
    protys:OEEPercent 88.0 ;
    protys:hasCapability protys:Batch_Mixing ;
    protys:temperatureCelsius 40.0 ;
    protys:speedRPM 150.0 ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/equipment/MixingReactor_02"^^xsd:anyURI ;
