    protys:hasName "Auto_Packaging_Capability" .

# ========================================
# MANUFACTURING PROCESSES
# ========================================

protys:RawMaterialInspection
    rdf:type protys:Inspection ;
    rdfs:label "Raw Material Inspection"@en ;
    rdfs:label "Inspección de Materia Prima"@es ;
    protys:hasName "RawMaterialInspection" ;
    protys:hasDescription "Quality inspection of incoming raw materials" ;
    protys:durationMinutes 15.0 ;
    protys:precedes protys:PigmentDispersion ;
    protys:belongsTo protys:Workshop_QC ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/process/RawMatInsp_001"^^xsd:anyURI .

protys:PigmentDispersion
    rdf:type protys:Procedure_Activity ;
    rdfs:label "Pigment Dispersion"@en ;
    rdfs:label "Dispersión de Pigmento"@es ;
    protys:hasName "PigmentDispersion" ;
    protys:hasDescription "Fine grinding and dispersion of TiO2 pigment using pearl mill" ;
    protys:durationMinutes 45.0 ;
    protys:inputQuantity 500.0 ;
    protys:outputQuantity 485.0 ;
    protys:yieldPercent 97.0 ;
    protys:speedRPM 1500.0 ;
    protys:throughput 11.1 ;
    protys:requiresResource protys:PearlMill_01 ;
    protys:inputMaterial protys:TiO2_Material ;
    protys:outputProduct protys:PigmentPaste_Intermediate ;
    protys:precedes protys:MainMixing ;
    protys:belongsTo protys:Cell_Dispersion ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/process/PigmentDisp_001"^^xsd:anyURI .

protys:MainMixing
    rdf:type protys:BatchProcess ;
    rdfs:label "Main Mixing"@en ;
    rdfs:label "Mezcla Principal"@es ;
    protys:hasName "MainMixing" ;
    protys:hasDescription "Batch mixing of pigment paste with acrylic resin and solvents" ;
    protys:durationMinutes 25.0 ;
    protys:inputQuantity 485.0 ;
    protys:outputQuantity 510.0 ;
    protys:yieldPercent 105.0 ;
    protys:temperatureCelsius 45.0 ;
    protys:speedRPM 250.0 ;
    protys:throughput 20.4 ;
    protys:requiresResource protys:MixingReactor_02 ;
    protys:inputMaterial protys:PigmentPaste_Intermediate ;
    protys:inputMaterial protys:AcrylicResin ;
    protys:inputMaterial protys:AqueousSolvent ;
    protys:outputProduct protys:AdjustedMix_Intermediate ;
    protys:precedes protys:ViscosityAdjustment ;
    protys:belongsTo protys:Cell_Mixing ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/process/MainMix_001"^^xsd:anyURI .

protys:ViscosityAdjustment
    rdf:type protys:Procedure_Activity ;
    rdfs:label "Viscosity Adjustment"@en ;
    rdfs:label "Ajuste de Viscosidad"@es ;
    protys:hasName "ViscosityAdjustment" ;
    protys:hasDescription "Fine-tuning of paint viscosity to specifications using rheology modifiers" ;
    protys:durationMinutes 15.0 ;
    protys:inputQuantity 510.0 ;
    protys:outputQuantity 515.0 ;
    protys:yieldPercent 101.0 ;
    protys:requiresResource protys:DosingSystem_03 ;
    protys:inputMaterial protys:RheologyModifier ;
    protys:precedes protys:Filtration ;
    protys:belongsTo protys:Cell_Mixing ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/process/ViscAdj_001"^^xsd:anyURI .

protys:Filtration
    rdf:type protys:Procedure_Activity ;
    rdfs:label "Filtration"@en ;
    rdfs:label "Filtración"@es ;
    protys:hasName "Filtration" ;
    protys:hasDescription "Removal of coarse particles and agglomerates through filtration" ;
    protys:durationMinutes 10.0 ;
    protys:inputQuantity 515.0 ;
    protys:outputQuantity 512.0 ;
    protys:yieldPercent 99.4 ;
    protys:throughput 51.2 ;
    protys:precedes protys:QualityControl ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/process/Filtration_001"^^xsd:anyURI .

protys:QualityControl
    rdf:type protys:QualityControl ;
    rdfs:label "Quality Control"@en ;
    rdfs:label "Control de Calidad"@es ;
    protys:hasName "QualityControl" ;
    protys:hasDescription "Comprehensive quality testing and verification of final paint formulation" ;
    protys:durationMinutes 30.0 ;
    protys:inputQuantity 512.0 ;
    protys:requiresResource protys:Workshop_QC ;
    protys:precedes protys:Packaging ;
    protys:belongsTo protys:Workshop_QC ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/process/QC_001"^^xsd:anyURI .

protys:Packaging
    rdf:type protys:Packaging ;
    rdfs:label "Packaging"@en ;
    rdfs:label "Empaquetado"@es ;
    protys:hasName "Packaging" ;
    protys:hasDescription "Automatic packaging of finished paint into containers" ;
    protys:durationMinutes 20.0 ;
    protys:inputQuantity 500.0 ;
    protys:outputQuantity 500.0 ;
    protys:yieldPercent 100.0 ;
    protys:capacityUnitsPerMinute 75.0 ;
    protys:throughput 25.0 ;
    protys:requiresResource protys:PackagingMachine_05 ;
    protys:outputProduct protys:WhitePaint_WaterBased ;
    protys:belongsTo protys:Cell_Packaging ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/process/Packaging_001"^^xsd:anyURI .

