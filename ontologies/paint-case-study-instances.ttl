# ========================================
# PAINT MANUFACTURING CASE STUDY INSTANCES
# ========================================

# ========================================
# MATERIALS
# ========================================

protys:TiO2_Material
    rdf:type protys:Raw_Material ;
    rdfs:label "Titanium Dioxide (TiO2)"@en ;
    rdfs:label "Dióxido de Titanio (TiO2)"@es ;
    protys:hasName "TiO2 Pigment" ;
    protys:hasDescription "High-purity titanium dioxide for white paint formulations" ;
    protys:carbonFootprintKgCO2eq 5.3 ;
    protys:waterFootprintLiters 45.0 ;
    protys:particleSize 0.25 ;
    protys:purityPercent 98.0 ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/material/TiO2_001"^^xsd:anyURI .

protys:AcrylicResin
    rdf:type protys:Chemical_Compound ;
    rdfs:label "Acrylic Resin"@en ;
    rdfs:label "Resina Acrílica"@es ;
    protys:hasName "Acrylic Binder Resin" ;
    protys:hasDescription "Water-soluble acrylic resin for paint binder formulation" ;
    protys:waterFootprintLiters 127.0 ;
    protys:volatileOrganicCompounds 2.5 ;
    protys:solidContent 45.0 ;
    protys:viscosity 500.0 ;
    protys:shelfLifeMonths 12 ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/material/AcrylicResin_001"^^xsd:anyURI .

protys:AqueousSolvent
    rdf:type protys:Raw_Material ;
    rdfs:label "Aqueous Solvent"@en ;
    rdfs:label "Disolvente Acuoso"@es ;
    protys:hasName "Water Solvent" ;
    protys:hasDescription "Deionized water used as primary solvent" ;
    protys:waterFootprintLiters 100.0 ;
    protys:solidContent 0.0 ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/material/H2O_001"^^xsd:anyURI .

protys:DispersantAdditive
    rdf:type protys:Chemical_Compound ;
    rdfs:label "Dispersant Additive"@en ;
    rdfs:label "Aditivo Dispersante"@es ;
    protys:hasName "Pigment Dispersant" ;
    protys:hasDescription "Additive to improve pigment dispersion and stability" ;
    protys:volatileOrganicCompounds 0.5 ;
    protys:solidContent 85.0 ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/material/Dispersant_001"^^xsd:anyURI .

protys:AntifoamAdditive
    rdf:type protys:Chemical_Compound ;
    rdfs:label "Antifoam Additive"@en ;
    rdfs:label "Aditivo Antiespuma"@es ;
    protys:hasName "Silicone-based Antifoam" ;
    protys:hasDescription "Reduces foam formation during mixing and application" ;
    protys:solidContent 80.0 ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/material/Antifoam_001"^^xsd:anyURI .

protys:Biocide
    rdf:type protys:Chemical_Compound ;
    rdfs:label "Biocide"@en ;
    rdfs:label "Biocida"@es ;
    protys:hasName "Preservative Biocide" ;
    protys:hasDescription "Antimicrobial agent for product preservation" ;
    protys:solidContent 100.0 ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/material/Biocide_001"^^xsd:anyURI .

protys:RheologyModifier
    rdf:type protys:Chemical_Compound ;
    rdfs:label "Rheology Modifier"@en ;
    rdfs:label "Modificador de Reología"@es ;
    protys:hasName "Viscosity Control Agent" ;
    protys:hasDescription "Controls paint viscosity and flow properties" ;
    protys:solidContent 75.0 ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/material/RheologyMod_001"^^xsd:anyURI .

# ========================================
# EQUIPMENT/MACHINERY
# ========================================

protys:PearlMill_01
    rdf:type protys:Equipment ;
    rdfs:label "Pearl Mill Unit 01"@en ;
    rdfs:label "Molino de Perlas Unidad 01"@es ;
    protys:hasName "PearlMill_01" ;
    protys:hasDescription "Horizontal pearl mill for fine grinding and pigment dispersion" ;
    protys:energyConsumptionKW 75.0 ;
    protys:capacityLitersPerHour 500.0 ;
    protys:availabilityPercent 85.0 ;
    protys:OEEPercent 82.0 ;
    protys:hasCapability protys:Fine_Grinding ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/equipment/PearlMill_01"^^xsd:anyURI ;
    protys:belongsTo protys:Cell_Dispersion .

protys:Fine_Grinding
    rdf:type protys:ManufacturingCapability ;
