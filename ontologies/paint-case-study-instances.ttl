    protys:impactUnit "KU (Krebs Units)" ;
    protys:hasURI "http://protys.ingar.conicet.gob.ar/spec/Viscosity_001"^^xsd:anyURI .

protys:ParticleSize_Hegman_Spec
    rdf:type protys:QualitySpec ;
    rdfs:label "Particle Size Specification (Hegman)"@en ;
    rdfs:label "Especificación de Tamaño de Partícula (Hegman)"@es ;
    protys:hasName "ParticleSize_Hegman_7plus" ;
    protys:hasDescription "Hegman grind gauge reading must be 7 or greater (finer than 25 micrometers)" ;
