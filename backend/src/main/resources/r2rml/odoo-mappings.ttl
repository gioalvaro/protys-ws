@prefix rr: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix rrml: <http://semweb.mmlab.be/ns/rrml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://example.org/> .
@prefix protys: <http://www.protys.org/ontology/protys#> .
@prefix protys-kb: <http://www.protys.org/ontology/protys-kb#> .

# ============================================================================
# ODOO 16.x R2RML MAPPINGS FOR PROTYS-WS
# ============================================================================
# This file contains R2RML mappings to transform Odoo 16 relational data
# into RDF triples conforming to the PROTYS(KB) ontology network.
# Case study: Paint manufacturing with TiO2, Acrylic Resin, PearlMill_01
# ============================================================================

# TriplesMap 1: product_template + product_product → protys:Raw_Material / protys:Final_Product
<#ProductMapping>
	a rr:TriplesMap ;
	rml:logicalSource [
		rml:source "jdbc:postgresql://localhost:5432/odoo" ;
		rml:sqlVersion rml:SQL2008 ;
		rml:query """
			SELECT
				pt.id as TemplateID,
				pp.id as ProductID,
				pt.name as ProductName,
				pt.description as ProductDescription,
				pt.default_code as ProductCode,
				pc.name as CategoryName,
				pp.type as ProductType,
				pt.create_date,
				pt.categ_id
			FROM product_template pt
			LEFT JOIN product_category pc ON pt.categ_id = pc.id
			LEFT JOIN product_product pp ON pt.id = pp.product_tmpl_id
			WHERE pt.active = true
		"""
	] ;
	rr:subjectMap [
		rr:template "http://example.org/odoo/product/{TemplateID}" ;
		rr:class protys:Material ;
		rr:class [
			rr:condition "ProductType = 'consu'" ;
			rr:class protys:Raw_Material ;
		] ;
		rr:class [
			rr:condition "ProductType = 'product'" ;
			rr:class protys:Final_Product ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate rdfs:label ;
		rr:objectMap [ rml:reference "ProductName" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasDescription ;
		rr:objectMap [ rml:reference "ProductDescription" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasCode ;
		rr:objectMap [ rml:reference "ProductCode" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasCategory ;
		rr:objectMap [ rml:reference "CategoryName" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:createdAt ;
		rr:objectMap [
			rml:reference "create_date" ;
			rr:datatype xsd:dateTime ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasProductVariant ;
		rr:objectMap [
			rr:template "http://example.org/odoo/product-variant/{ProductID}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:source ;
		rr:objectMap [
			rr:constant "http://example.org/source/odoo" ;
			rr:termType rr:IRI ;
		] ;
	] .

# TriplesMap 2: product_product (variants)
<#ProductVariantMapping>
	a rr:TriplesMap ;
	rml:logicalSource [
		rml:source "jdbc:postgresql://localhost:5432/odoo" ;
		rml:sqlVersion rml:SQL2008 ;
		rml:query """
			SELECT
				pp.id as VariantID,
				pp.product_tmpl_id as TemplateID,
				pp.name as VariantName,
				pp.default_code as VariantCode,
				pt.name as ProductName
			FROM product_product pp
			LEFT JOIN product_template pt ON pp.product_tmpl_id = pt.id
			WHERE pt.active = true
		"""
	] ;
	rr:subjectMap [
		rr:template "http://example.org/odoo/product-variant/{VariantID}" ;
		rr:class protys:ProductVariant ;
	] ;
	rr:predicateObjectMap [
		rr:predicate rdfs:label ;
		rr:objectMap [ rml:reference "VariantName" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasCode ;
		rr:objectMap [ rml:reference "VariantCode" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:isVariantOf ;
		rr:objectMap [
			rr:template "http://example.org/odoo/product/{TemplateID}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:source ;
		rr:objectMap [
			rr:constant "http://example.org/source/odoo" ;
			rr:termType rr:IRI ;
		] ;
	] .

# TriplesMap 3: mrp_production + mrp_workorder → protys:Artificial_Process / protys:BatchProcess
<#ProductionMapping>
	a rr:TriplesMap ;
	rml:logicalSource [
		rml:source "jdbc:postgresql://localhost:5432/odoo" ;
		rml:sqlVersion rml:SQL2008 ;
		rml:query """
			SELECT
				mp.id as ProductionID,
				mp.product_id as ProductID,
				mp.name as ProductionName,
				mp.date_planned_start as StartDate,
				mp.date_planned_finished as EndDate,
				mp.product_qty as PlannedQuantity,
				mp.qty_produced as ProducedQuantity,
				mp.state as Status,
				mw.id as WorkOrderID,
				mw.state as WorkOrderStatus,
				mw.date_start as WorkOrderStart,
				mw.date_finished as WorkOrderEnd
			FROM mrp_production mp
			LEFT JOIN mrp_workorder mw ON mp.id = mw.production_id
			WHERE mp.state != 'cancel'
		"""
	] ;
	rr:subjectMap [
		rr:template "http://example.org/odoo/production/{ProductionID}" ;
		rr:class protys:Artificial_Process ;
		rr:class protys:BatchProcess ;
	] ;
	rr:predicateObjectMap [
		rr:predicate rdfs:label ;
		rr:objectMap [ rml:reference "ProductionName" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasProduct ;
		rr:objectMap [
			rr:template "http://example.org/odoo/product/{ProductID}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasStartTime ;
		rr:objectMap [
			rml:reference "StartDate" ;
			rr:datatype xsd:dateTime ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasEndTime ;
		rr:objectMap [
			rml:reference "EndDate" ;
			rr:datatype xsd:dateTime ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasPlannedQuantity ;
		rr:objectMap [
			rml:reference "PlannedQuantity" ;
			rr:datatype xsd:decimal ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasActualQuantity ;
		rr:objectMap [
			rml:reference "ProducedQuantity" ;
			rr:datatype xsd:decimal ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasStatus ;
		rr:objectMap [ rml:reference "Status" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasWorkOrder ;
		rr:objectMap [
			rr:template "http://example.org/odoo/workorder/{WorkOrderID}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:source ;
		rr:objectMap [
			rr:constant "http://example.org/source/odoo" ;
			rr:termType rr:IRI ;
		] ;
	] .

# TriplesMap 4: mrp_workorder Details
<#WorkOrderMapping>
	a rr:TriplesMap ;
	rml:logicalSource [
		rml:source "jdbc:postgresql://localhost:5432/odoo" ;
		rml:sqlVersion rml:SQL2008 ;
		rml:query """
			SELECT
				mw.id as WorkOrderID,
				mw.production_id as ProductionID,
				mw.name as WorkOrderName,
				mw.workcenter_id as WorkCenterID,
				mw.date_start as StartDate,
				mw.date_finished as FinishedDate,
				mw.state as Status,
				mw.qty_producing as Quantity
			FROM mrp_workorder mw
			WHERE mw.state != 'cancel'
		"""
	] ;
	rr:subjectMap [
		rr:template "http://example.org/odoo/workorder/{WorkOrderID}" ;
		rr:class protys:WorkOrder ;
	] ;
	rr:predicateObjectMap [
		rr:predicate rdfs:label ;
		rr:objectMap [ rml:reference "WorkOrderName" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:partOfProduction ;
		rr:objectMap [
			rr:template "http://example.org/odoo/production/{ProductionID}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasStartTime ;
		rr:objectMap [
			rml:reference "StartDate" ;
			rr:datatype xsd:dateTime ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasEndTime ;
		rr:objectMap [
			rml:reference "FinishedDate" ;
			rr:datatype xsd:dateTime ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasStatus ;
		rr:objectMap [ rml:reference "Status" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasQuantity ;
		rr:objectMap [
			rml:reference "Quantity" ;
			rr:datatype xsd:decimal ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:source ;
		rr:objectMap [
			rr:constant "http://example.org/source/odoo" ;
			rr:termType rr:IRI ;
		] ;
	] .

# TriplesMap 5: mrp_bom + mrp_bom_line → protys:Formulation
<#BOMMapping>
	a rr:TriplesMap ;
	rml:logicalSource [
		rml:source "jdbc:postgresql://localhost:5432/odoo" ;
		rml:sqlVersion rml:SQL2008 ;
		rml:query """
			SELECT
				mb.id as BOMID,
				mb.product_id as FinalProductID,
				mb.code as BOMCode,
				mb.type as BOMType,
				mbl.id as BOMLineID,
				mbl.product_id as ComponentProductID,
				mbl.product_qty as Quantity,
				mbl.product_uom_id as UOMId,
				mbl.sequence as LineNumber
			FROM mrp_bom mb
			LEFT JOIN mrp_bom_line mbl ON mb.id = mbl.bom_id
			WHERE mb.active = true
		"""
	] ;
	rr:subjectMap [
		rr:template "http://example.org/odoo/bom/{BOMID}" ;
		rr:class protys:Formulation ;
	] ;
	rr:predicateObjectMap [
		rr:predicate rdfs:label ;
		rr:objectMap [ rml:reference "BOMCode" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasFinalProduct ;
		rr:objectMap [
			rr:template "http://example.org/odoo/product/{FinalProductID}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasComponent ;
		rr:objectMap [
			rr:template "http://example.org/odoo/bom-line/{BOMLineID}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasBOMType ;
		rr:objectMap [ rml:reference "BOMType" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:source ;
		rr:objectMap [
			rr:constant "http://example.org/source/odoo" ;
			rr:termType rr:IRI ;
		] ;
	] .

# TriplesMap 6: mrp_bom_line Details
<#BOMLineMapping>
	a rr:TriplesMap ;
	rml:logicalSource [
		rml:source "jdbc:postgresql://localhost:5432/odoo" ;
		rml:sqlVersion rml:SQL2008 ;
		rml:query """
			SELECT
				mbl.id as BOMLineID,
				mbl.bom_id as BOMID,
				mbl.product_id as ProductID,
				mbl.product_qty as Quantity,
				mbl.product_uom_id as UOMId,
				mbl.sequence as LineNumber,
				pt.name as ProductName
			FROM mrp_bom_line mbl
			LEFT JOIN product_product pp ON mbl.product_id = pp.id
			LEFT JOIN product_template pt ON pp.product_tmpl_id = pt.id
			WHERE mbl.active = true
		"""
	] ;
	rr:subjectMap [
		rr:template "http://example.org/odoo/bom-line/{BOMLineID}" ;
		rr:class protys:Component ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasProduct ;
		rr:objectMap [
			rr:template "http://example.org/odoo/product/{ProductID}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasQuantity ;
		rr:objectMap [
			rml:reference "Quantity" ;
			rr:datatype xsd:decimal ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasUnitOfMeasure ;
		rr:objectMap [
			rr:template "http://example.org/odoo/uom/{UOMId}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:lineNumber ;
		rr:objectMap [
			rml:reference "LineNumber" ;
			rr:datatype xsd:integer ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:source ;
		rr:objectMap [
			rr:constant "http://example.org/source/odoo" ;
			rr:termType rr:IRI ;
		] ;
	] .

# TriplesMap 7: res_company → protys:Organization
<#CompanyMapping>
	a rr:TriplesMap ;
	rml:logicalSource [
		rml:source "jdbc:postgresql://localhost:5432/odoo" ;
		rml:sqlVersion rml:SQL2008 ;
		rml:query """
			SELECT
				rc.id as CompanyID,
				rc.name as CompanyName,
				rc.parent_id as ParentCompanyID,
				rc.create_date
			FROM res_company rc
			WHERE rc.active = true
		"""
	] ;
	rr:subjectMap [
		rr:template "http://example.org/odoo/company/{CompanyID}" ;
		rr:class protys:Organization ;
	] ;
	rr:predicateObjectMap [
		rr:predicate rdfs:label ;
		rr:objectMap [ rml:reference "CompanyName" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasParentOrganization ;
		rr:objectMap [
			rr:template "http://example.org/odoo/company/{ParentCompanyID}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:createdAt ;
		rr:objectMap [
			rml:reference "create_date" ;
			rr:datatype xsd:dateTime ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:source ;
		rr:objectMap [
			rr:constant "http://example.org/source/odoo" ;
			rr:termType rr:IRI ;
		] ;
	] .

# TriplesMap 8: stock_warehouse → protys:Warehouse
<#WarehouseMapping>
	a rr:TriplesMap ;
	rml:logicalSource [
		rml:source "jdbc:postgresql://localhost:5432/odoo" ;
		rml:sqlVersion rml:SQL2008 ;
		rml:query """
			SELECT
				sw.id as WarehouseID,
				sw.name as WarehouseName,
				sw.company_id as CompanyID,
				sw.code as WarehouseCode
			FROM stock_warehouse sw
			WHERE sw.active = true
		"""
	] ;
	rr:subjectMap [
		rr:template "http://example.org/odoo/warehouse/{WarehouseID}" ;
		rr:class protys:Warehouse ;
	] ;
	rr:predicateObjectMap [
		rr:predicate rdfs:label ;
		rr:objectMap [ rml:reference "WarehouseName" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasCode ;
		rr:objectMap [ rml:reference "WarehouseCode" ] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:belongsToOrganization ;
		rr:objectMap [
			rr:template "http://example.org/odoo/company/{CompanyID}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:source ;
		rr:objectMap [
			rr:constant "http://example.org/source/odoo" ;
			rr:termType rr:IRI ;
		] ;
	] .

# TriplesMap 9: stock_quant → Stock Levels
<#StockQuantMapping>
	a rr:TriplesMap ;
	rml:logicalSource [
		rml:source "jdbc:postgresql://localhost:5432/odoo" ;
		rml:sqlVersion rml:SQL2008 ;
		rml:query """
			SELECT
				sq.id as QuantID,
				sq.product_id as ProductID,
				sq.location_id as LocationID,
				sq.quantity as Quantity,
				sq.reserved_quantity as ReservedQuantity,
				sq.company_id as CompanyID,
				sq.create_date
			FROM stock_quant sq
			WHERE sq.quantity > 0
		"""
	] ;
	rr:subjectMap [
		rr:template "http://example.org/odoo/stock-quant/{QuantID}" ;
		rr:class protys:Inventory ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasProduct ;
		rr:objectMap [
			rr:template "http://example.org/odoo/product/{ProductID}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasQuantity ;
		rr:objectMap [
			rml:reference "Quantity" ;
			rr:datatype xsd:decimal ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:hasReservedQuantity ;
		rr:objectMap [
			rml:reference "ReservedQuantity" ;
			rr:datatype xsd:decimal ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:measuredAt ;
		rr:objectMap [
			rml:reference "create_date" ;
			rr:datatype xsd:dateTime ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:belongsToOrganization ;
		rr:objectMap [
			rr:template "http://example.org/odoo/company/{CompanyID}" ;
			rr:termType rr:IRI ;
		] ;
	] ;
	rr:predicateObjectMap [
		rr:predicate protys:source ;
		rr:objectMap [
			rr:constant "http://example.org/source/odoo" ;
			rr:termType rr:IRI ;
		] ;
	] .
